local content = Instance.new("Frame", main)
content.Size = UDim2.new(1,-100,1,-40)
content.Position = UDim2.new(0,100,0,40)

-- FUNCTION CREATE BUTTON
function createButton(parent, text, y, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1,0,0,40)
    btn.Position = UDim2.new(0,0,0,y)
    btn.Text = text
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- STATES
local autoFarm = false
local autoQuest = false

-- MAIN TAB
local mainTab = Instance.new("Frame", content)
mainTab.Size = UDim2.new(1,0,1,0)

createButton(mainTab, "Toggle Auto Farm", 0, function()
    autoFarm = not autoFarm
    while autoFarm do
        print("Farming...")
        task.wait(1)
    end
end)

createButton(mainTab, "Toggle Auto Quest", 50, function()
    autoQuest = not autoQuest
    while autoQuest do
        print("Doing quest...")
        task.wait(2)
    end
end)

-- TELEPORT TAB
local tpTab = Instance.new("Frame", content)
