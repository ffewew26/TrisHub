local Core = {}
Core.Functions = {}
Core.Loops = {}
Core.Enabled = {}

function Core:CreateLoop(name, func, delay)
    Core.Enabled[name] = false

    Core.Loops[name] = function()
        task.spawn(function()
            while Core.Enabled[name] do
                local success, err = pcall(func)
                if not success then
                    warn("Error in "..name..": "..err)
                end
                task.wait(delay or 0.2)
            end
        end)
    end
end

function Core:Start(name)
    if Core.Loops[name] then
        Core.Enabled[name] = true
        Core.Loops[name]()
    end
end

function Core:Stop(name)
    Core.Enabled[name] = false
end

