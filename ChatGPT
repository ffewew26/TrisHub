local autoFruit = false

local function UseSkills()
    local char = player.Character
    if not char then return end

    for _,v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            pcall(function()
                v:Activate()
            end)
        end
    end
end

Core:CreateLoop("AutoSkill", function()
    if autoSkill then
        UseSkills()
    end
end, 0.3)

local function FindFruit()
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Tool") and string.find(v.Name:lower(), "fruit") then
            return v
        end
    end
end

local function Notify(msg)
    pcall(function()
        game.StarterGui:SetCore("SendNotification", {
            Title = "TrisHub",
            Text = msg,
            Duration = 4
        })
    end)
end

local found = {}

Core:CreateLoop("FruitDetect", function()
    if autoFruit then
        local fruit = FindFruit()
        if fruit and not found[fruit] then
            found[fruit] = true
            Notify("Fruit detected: "..fruit.Name)
        end
    end
end, 2)

local gui = player.PlayerGui:FindFirstChild("TrisHub")
local main = gui and gui:FindFirstChildWhichIsA("Frame")

if main then
    local farmPage

    for _,v in pairs(main:GetChildren()) do
        if v:IsA("Frame") and v.Visible then
            farmPage = v
        end
    end

    if farmPage then
        local skillBtn = Instance.new("TextButton", farmPage)
        skillBtn.Size = UDim2.new(0,200,0,40)
        skillBtn.Position = UDim2.new(0,10,0,380)
        skillBtn.Text = "Auto Skill [OFF]"
        skillBtn.BackgroundColor3 = Color3.fromRGB(30,30,45)
        skillBtn.TextColor3 = Color3.new(1,1,1)

        skillBtn.MouseButton1Click:Connect(function()
            autoSkill = not autoSkill
            skillBtn.Text = "Auto Skill ["..(autoSkill and "ON" or "OFF").."]"

            if autoSkill then
                Core:Start("AutoSkill")
            else
                Core:Stop("AutoSkill")
            end
        end)

        local fruitBtn = Instance.new("TextButton", farmPage)
        fruitBtn.Size = UDim2.new(0,200,0,40)
        fruitBtn.Position = UDim2.new(0,10,0,430)
        fruitBtn.Text = "Fruit Detect [OFF]"
        fruitBtn.BackgroundColor3 = Color3.fromRGB(30,30,45)
        fruitBtn.TextColor3 = Color3.new(1,1,1)

        fruitBtn.MouseButton1Click:Connect(function()
            autoFruit = not autoFruit
            fruitBtn.Text = "Fruit Detect ["..(autoFruit and "ON" or "OFF").."]"

            if autoFruit then
                Core:Start("FruitDetect")
            else
                Core:Stop("FruitDetect")
            end
        end)
    end
end
